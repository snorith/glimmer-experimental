# Auto-detect text files and perform LF normalization
* text=auto

# Source code files
*.java text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.groovy text eol=lf
*.gradle text eol=lf
*.gradle.kts text eol=lf
*.scala text eol=lf
*.clj text eol=lf

# Build and configuration files
*.xml text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.properties text eol=lf
*.conf text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
build.gradle text eol=lf
settings.gradle text eol=lf
pom.xml text eol=lf
Dockerfile text eol=lf
docker-compose*.yml text eol=lf
*.dockerfile text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.less text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.vue text eol=lf
*.svg text eol=lf

# Documentation and text files
*.md text eol=lf
*.txt text eol=lf
*.adoc text eol=lf
*.rst text eol=lf
*.tex text eol=lf
README* text eol=lf
CHANGELOG* text eol=lf
LICENSE* text eol=lf
NOTICE* text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.fish text eol=lf
*.ps1 text eol=crlf

# Batch scripts (Windows)
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files - mark as binary to prevent git from trying to diff/merge them
*.jar binary
*.war binary
*.ear binary
*.aar binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.rar binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.class binary

# Images
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary
*.svg binary
*.webp binary
*.bmp binary
*.tiff binary

# Fonts
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary

# Video and audio
*.mp4 binary
*.avi binary
*.mov binary
*.wmv binary
*.flv binary
*.mp3 binary
*.wav binary
*.ogg binary

# PDF and Office documents
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary

# IDE and editor files
*.iml text eol=lf
*.ipr text eol=lf
*.iws text eol=lf

# Maven wrapper
mvnw text eol=lf
mvnw.cmd text eol=crlf
.mvn/wrapper/maven-wrapper.properties text eol=lf

# Gradle wrapper
gradlew text eol=lf
gradlew.bat text eol=crlf
gradle/wrapper/gradle-wrapper.properties text eol=lf

# Git files
.gitignore text eol=lf
.gitattributes text eol=lf
.gitmodules text eol=lf

# Language-specific export-ignore patterns (files not included in git archive)
.github/ export-ignore
.gitlab/ export-ignore
.circleci/ export-ignore
.travis.yml export-ignore
.appveyor.yml export-ignore
codecov.yml export-ignore
.codecov.yml export-ignore